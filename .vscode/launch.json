{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run compiler package",
      "type": "debugpy",
      "request": "launch",
      "module": "compiler",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "args": [
        "--input",
        "fortran-stencils/elmm_cdv.f90",

        "--output-dir",
        "out",

        "--kernel",
        "CDV"
      ]
    }
  ]
}
